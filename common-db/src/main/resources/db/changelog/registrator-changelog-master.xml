<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="db.schema" value="registrator_schema"/>

    <!-- ======================= -->
    <!--   Таблица apartment     -->
    <!-- ======================= -->
    <changeSet id="registrator-001-create-apartment" author="team-registrator">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="apartment" schemaName="${db.schema}"/>
            </not>
        </preConditions>

        <createTable tableName="apartment" schemaName="${db.schema}">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="number" type="BIGINT"/>
            <column name="floor" type="BIGINT"/>
            <column name="number_of_rooms" type="BIGINT"/>
            <column name="is_vacant" type="BOOLEAN"/>
        </createTable>

        <rollback>
            <dropTable tableName="apartment" schemaName="${db.schema}"/>
        </rollback>
    </changeSet>

    <!-- ======================= -->
    <!--   Таблица resident      -->
    <!-- ======================= -->
    <changeSet id="registrator-002-create-resident" author="team-registrator">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="resident" schemaName="${db.schema}"/>
            </not>
        </preConditions>

        <createTable tableName="resident" schemaName="${db.schema}">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="generated_id" type="BIGINT"/>

            <column name="name" type="VARCHAR(255)"/>
        </createTable>

        <rollback>
            <dropTable tableName="resident" schemaName="${db.schema}"/>
        </rollback>
    </changeSet>

    <!-- ======================= -->
    <!--   Таблица booking_info  -->
    <!-- ======================= -->
    <changeSet id="registrator-003-create-booking-info" author="team-registrator">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="booking_info" schemaName="${db.schema}"/>
            </not>
        </preConditions>

        <createTable tableName="booking_info" schemaName="${db.schema}">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="apartment_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="resident_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="booked_at" type="TIMESTAMP WITH TIME ZONE"/>

            <column name="booking_status" type="VARCHAR(50)"/>

            <column name="payment_uid" type="UUID"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="booking_info"
                baseColumnNames="apartment_id"
                constraintName="fk_booking_info_apartment"
                referencedTableName="apartment"
                referencedColumnNames="id"
                baseTableSchemaName="${db.schema}"
                referencedTableSchemaName="${db.schema}"/>

        <addForeignKeyConstraint
                baseTableName="booking_info"
                baseColumnNames="resident_id"
                constraintName="fk_booking_info_resident"
                referencedTableName="resident"
                referencedColumnNames="id"
                baseTableSchemaName="${db.schema}"
                referencedTableSchemaName="${db.schema}"/>

        <rollback>
            <dropColumn tableName="booking_info" columnName="payment_status" schemaName="${db.schema}"/>
            <dropColumn tableName="booking_info" columnName="payment_uid" schemaName="${db.schema}"/>
        </rollback>
    </changeSet>

    <changeSet id="registrator-004-insert-apartments" author="team-registrator">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="apartment" schemaName="${db.schema}"/>
        </preConditions>

        <sql>
            INSERT INTO ${db.schema}.apartment (number, floor, number_of_rooms, is_vacant) VALUES
                                                                                               (101, 1, 1, TRUE),
                                                                                               (202, 2, 2, TRUE),
                                                                                               (303, 3, 3, TRUE),
                                                                                               (404, 4, 2, TRUE),
                                                                                               (505, 5, 1, TRUE);
        </sql>

        <rollback>
            DELETE FROM ${db.schema}.apartment
            WHERE number IN (101, 202, 303, 404, 505);
        </rollback>
    </changeSet>


</databaseChangeLog>
