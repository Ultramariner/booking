<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <property name="db.schema" value="payment_schema"/>

    <changeSet id="payment-001-create-payment-info" author="team-payment">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="payment_info" schemaName="${db.schema}"/>
            </not>
        </preConditions>

        <createTable tableName="payment_info" schemaName="${db.schema}">
            <column name="uid" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="booking_id" type="BIGINT"/>

            <column name="person" type="VARCHAR(255)"/>

            <column name="amount" type="NUMERIC(15,2)"/>

            <column name="status" type="VARCHAR(50)"/>

            <column name="processed_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <rollback>
            <dropTable tableName="payment_info" schemaName="${db.schema}"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
