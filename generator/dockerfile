# ---------- Build ----------
FROM maven:3.9.6-eclipse-temurin-21 AS build
WORKDIR /app

COPY common-db ./common-db
RUN mvn -q -e -DskipTests -f common-db/pom.xml install

COPY feign-clients ./feign-clients
RUN mvn -q -e -DskipTests -f feign-clients/pom.xml install

COPY generator ./generator

RUN mvn -q -e -DskipTests -f generator/pom.xml package

# ---------- Run ----------
FROM eclipse-temurin:21-jre
WORKDIR /app

COPY --from=build /app/generator/target/generator-*.jar app.jar

ENTRYPOINT ["java", "-jar", "app.jar"]
